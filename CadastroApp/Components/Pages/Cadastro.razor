@page "/cadastro"
@page "/cadastro/{Id:int}"
@inject ViaCepService ViaCepService
@inject AuthService AuthService
@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@inject PessoaService PessoaService
@inject NavigationManager NavigationManager
@using Microsoft.JSInterop
@using Microsoft.Maui.ApplicationModel
@using Microsoft.Maui.ApplicationModel.DataTransfer
@using Microsoft.Maui.Storage
@using QuestPDF.Fluent
@using QuestPDF.Helpers
@using QuestPDF.Infrastructure
@using CadastroApp.Helpers
@using CadastroApp.Models
@using CadastroApp.Services


<h3>@tituloPagina</h3>



<EditForm Model="@pessoa" OnValidSubmit="Salvar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Nome:</label>
        <InputText @bind-Value="pessoa.Nome"
                   class="form-control"
                   placeholder="Digite o nome" />

    </div>

    <div class="mb-3">
        <label>E-mail:</label>
        <input type="email"
               value="@pessoa.Email"
               @oninput="FormatarEmail"
               class="form-control"
               placeholder="Digite um e-mail"
               inputmode="email"
               autocomplete="email"
               autocapitalize="none"
               spellcheck="false" />
    </div>

    <div class="mb-3">
        <label>CPF:</label>
        <input value="@pessoa.CPF"
               @oninput="FormatarCPF"
               maxlength="14"
               inputmode="numeric"
               class="form-control"
               placeholder="Digite o CPF" />
    </div>
    <div class="mb-3">
        <label>Telefone:</label>
        <input value="@pessoa.Telefone"
               @oninput="FormatarTelefone"
               class="form-control"
               placeholder="(00) 00000-0000"
               maxlength="15"
               inputmode="numeric" />
    </div>
    <div class="mb-3">
        <label>CEP:</label>
        <input value="@pessoa.CEP"
               @oninput="FormatarCEP"
               @onblur="BuscarEnderecoPorCep"
               maxlength="9"
               inputmode="numeric"
               class="form-control"
               placeholder="00000-000" />
    </div>

    <div class="mb-3">
        <label>Cidade:</label>
        <InputText @bind-Value="pessoa.Cidade"
                   class="form-control"
                   placeholder="Cidade" />
    </div>

    
    <div class="mb-3">
        <label>Bairro:</label>
        <InputText @bind-Value="pessoa.Bairro"
                   class="form-control"
                   placeholder="Bairro" />
    </div>


    <div class="mb-3">
        <label>Estado:</label>
        <InputText @bind-Value="pessoa.Estado"
                   class="form-control"
                   placeholder="UF" />
    </div>

    <div class="mb-3">
        <label>Rua:</label>
        <InputText @bind-Value="pessoa.Rua"
                   class="form-control"
                   placeholder="Rua" />
    </div>

    <div class="mb-3">
        <label>Nº:</label>
        <InputText @bind-Value="pessoa.Numero"
                   class="form-control"
                   placeholder="Número da residência" />
    </div>


   
    <div class="cadastro-acoes">

        <button type="submit" class="btn btn-primary cadastro-botao">
            @textoBotao
        </button>

        @if (Id.HasValue)
        {
            <button type="button"
                    class="btn btn-danger cadastro-botao"
                    @onclick="ExportarPdfCliente">
                Exportar PDF
            </button>

            <button type="button"
                    class="btn btn-success cadastro-botao"
                    @onclick="AbrirPdfCliente">
                Abrir/Imprimir PDF
            </button>
        }

        <button type="button"
                class="btn btn-secondary cadastro-botao"
                @onclick="Voltar">
            Voltar
        </button>

    </div>

</EditForm>

@if (!string.IsNullOrEmpty(mensagem))
{
    <p class="mt-3 text-success">@mensagem</p>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    Pessoa pessoa = new();
    string mensagem = string.Empty;
    string tituloPagina = "Cadastro de Cliente";
    string textoBotao = "Salvar";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.EstaLogado)
        {
            NavigationManager.NavigateTo("/");
            return;
        }
        if (Id.HasValue)
        {
            var pessoaEncontrada = await PessoaService.BuscarPorIdAsync(Id.Value);

            if (pessoaEncontrada is not null)
            {
                pessoa = pessoaEncontrada;
                tituloPagina = "Editar Cliente";
                textoBotao = "Atualizar";
            }
            else
            {
                mensagem = "Cliente não encontrado.";
            }
        }
    }

    void FormatarCEP(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString() ?? "";

        var numeros = new string(valor.Where(char.IsDigit).ToArray());

        if (numeros.Length > 8)
        {
            numeros = numeros.Substring(0, 8);
        }

        if (numeros.Length <= 5)
        {
            pessoa.CEP = numeros;
        }
        else
        {
            pessoa.CEP = $"{numeros.Substring(0, 5)}-{numeros.Substring(5)}";
        }
    }

    async Task Salvar()
    {

        pessoa.Email = pessoa.Email.Trim().ToLower();

        pessoa.DataCadastro = pessoa.Id == 0
                ? DateTime.Now
                : pessoa.DataCadastro;


        var cpfNumeros = CpfHelper.SomenteNumeros(pessoa.CPF);

        if (cpfNumeros.Length != 11)
        {
            mensagem = "CPF deve conter exatamente 11 números.";
            return;
        }

        bool cpfDuplicado = await PessoaService.CpfJaExisteAsync(pessoa.CPF, pessoa.Id);

        if (cpfDuplicado)
        {
            mensagem = "Este CPF já está cadastrado.";
            return;
        }

        pessoa.CPF = CpfHelper.FormatarCpf(pessoa.CPF);

        await PessoaService.SalvarAsync(pessoa);

        if (Id.HasValue)
        {
            mensagem = "Cadastro atualizado com sucesso!";
        }
        else
        {
            mensagem = "Cadastro salvo com sucesso!";
            pessoa = new Pessoa();
        }
    }

    async Task BuscarEnderecoPorCep()
    {
        try
        {
            var cepNumeros = new string(
                (pessoa.CEP ?? string.Empty).Where(char.IsDigit).ToArray()
            );

            if (cepNumeros.Length != 8)
            {
                return;
            }

            var endereco = await ViaCepService.BuscarCepAsync(cepNumeros);

            if (endereco is null)
            {
                await JSRuntime.InvokeVoidAsync(
                    "alert",
                    "CEP não encontrado."
                );

                return;
            }

            pessoa.CEP = endereco.Cep;
            pessoa.Rua = endereco.Logradouro;
            pessoa.Bairro = endereco.Bairro;
            pessoa.Cidade = endereco.Localidade;
            pessoa.Estado = endereco.Uf;
        }
        catch
        {
            await JSRuntime.InvokeVoidAsync(
                "alert",
                "Não foi possível consultar o CEP. Verifique sua conexão com a internet."
            );
        }
    }

    void FormatarTelefone(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString() ?? "";

        var numeros = new string(valor.Where(char.IsDigit).ToArray());

        if (numeros.Length > 11)
            numeros = numeros.Substring(0, 11);

        if (numeros.Length <= 2)
        {
            pessoa.Telefone = numeros;
        }
        else if (numeros.Length <= 6)
        {
            pessoa.Telefone = $"({numeros.Substring(0, 2)}) {numeros.Substring(2)}";
        }
        else if (numeros.Length <= 10)
        {
            pessoa.Telefone = $"({numeros.Substring(0, 2)}) {numeros.Substring(2, 4)}-{numeros.Substring(6)}";
        }
        else
        {
            pessoa.Telefone = $"({numeros.Substring(0, 2)}) {numeros.Substring(2, 5)}-{numeros.Substring(7)}";
        }
    }




    void Voltar()
    {
        NavigationManager.NavigateTo("/home");
    }

    void FormatarCPF(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString() ?? "";

        pessoa.CPF = CpfHelper.FormatarCpf(valor);
    }

    void FormatarEmail(ChangeEventArgs e)
    {
        pessoa.Email = (e.Value?.ToString() ?? string.Empty)
            .Trim()
            .ToLower();
    }

    async Task ExportarPdfCliente()
    {
        try
        {
            var caminhoArquivo = GerarPdfCliente();

            await Share.Default.RequestAsync(new ShareFileRequest
            {
                Title = "Exportar PDF do cliente",
                File = new ShareFile(caminhoArquivo)
            });
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync(
                "alert",
                $"Erro ao exportar PDF: {ex.Message}"
            );
        }
    }

    async Task AbrirPdfCliente()
    {
        try
        {
            var caminhoArquivo = GerarPdfCliente();

            await Launcher.Default.OpenAsync(new OpenFileRequest
            {
                File = new ReadOnlyFile(caminhoArquivo)
            });
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync(
                "alert",
                $"Erro ao abrir PDF: {ex.Message}"
            );
        }
    }

    string GerarPdfCliente()
    {
        var nomeUsuario = AuthService.UsuarioLogado?.Nome ?? "Usuário não identificado";
        var perfilUsuario = AuthService.UsuarioLogado?.Perfil ?? "Perfil não identificado";

        var nomeSeguro = CriarNomeArquivoSeguro(pessoa.Nome);

        var nomeArquivo = $"cliente_{nomeSeguro}_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";

        var caminhoArquivo = Path.Combine(
            FileSystem.CacheDirectory,
            nomeArquivo
        );

        Document.Create(container =>
        {
            container.Page(page =>
            {
                page.Size(PageSizes.A4);
                page.Margin(32);
                page.DefaultTextStyle(x => x.FontSize(10));

                page.Header()
                    .Column(header =>
                    {
                        header.Item()
                            .Row(row =>
                            {
                                row.ConstantItem(58)
                                    .Height(58)
                                    .Background(Colors.Blue.Medium)
                                    .AlignCenter()
                                    .AlignMiddle()
                                    .Text("CA")
                                    .FontColor(Colors.White)
                                    .FontSize(20)
                                    .Bold();

                                row.RelativeItem()
                                    .PaddingLeft(12)
                                    .Column(col =>
                                    {
                                        col.Item()
                                            .Text("CadastroApp")
                                            .FontSize(22)
                                            .Bold()
                                            .FontColor(Colors.Blue.Darken2);

                                        col.Item()
                                            .Text("Ficha Individual do Cliente")
                                            .FontSize(13)
                                            .FontColor(Colors.Grey.Darken2);

                                        col.Item()
                                            .Text($"Gerado em: {DateTime.Now:dd/MM/yyyy HH:mm}")
                                            .FontSize(9)
                                            .FontColor(Colors.Grey.Darken1);
                                    });
                            });

                        header.Item()
                            .PaddingTop(14)
                            .Background(Colors.Grey.Lighten4)
                            .Padding(10)
                            .Row(row =>
                            {
                                row.RelativeItem()
                                    .Column(col =>
                                    {
                                        col.Item()
                                            .Text("Usuário logado")
                                            .FontSize(8)
                                            .FontColor(Colors.Grey.Darken1);

                                        col.Item()
                                            .Text(nomeUsuario)
                                            .FontSize(11)
                                            .Bold();
                                    });

                                row.RelativeItem()
                                    .Column(col =>
                                    {
                                        col.Item()
                                            .Text("Perfil")
                                            .FontSize(8)
                                            .FontColor(Colors.Grey.Darken1);

                                        col.Item()
                                            .Text(perfilUsuario)
                                            .FontSize(11)
                                            .Bold();
                                    });
                            });

                        header.Item()
                            .PaddingTop(10)
                            .LineHorizontal(1)
                            .LineColor(Colors.Grey.Lighten1);
                    });

                page.Content()
                    .PaddingTop(18)
                    .Column(content =>
                    {
                        content.Item()
                            .Text("Dados do Cliente")
                            .FontSize(16)
                            .Bold()
                            .FontColor(Colors.Blue.Darken2);

                        content.Item()
                            .PaddingTop(10)
                            .Background(Colors.White)
                            .Border(1)
                            .BorderColor(Colors.Grey.Lighten2)
                            .Padding(14)
                            .Column(col =>
                            {
                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("Nome: ").Bold();
                                        text.Span(pessoa.Nome ?? "");
                                    });

                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("E-mail: ").Bold();
                                        text.Span(pessoa.Email ?? "");
                                    });

                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("CPF: ").Bold();
                                        text.Span(pessoa.CPF ?? "");
                                    });

                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("Telefone: ").Bold();
                                        text.Span(
                                            string.IsNullOrWhiteSpace(pessoa.Telefone)
                                                ? "Não informado"
                                                : pessoa.Telefone
                                        );
                                    });

                                col.Item().Element(CampoDetalhePdf)
.Text(text =>
{
    text.Span("CEP: ").Bold();
    text.Span(string.IsNullOrWhiteSpace(pessoa.CEP) ? "Não informado" : pessoa.CEP);
});

                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("Rua: ").Bold();
                                        text.Span(string.IsNullOrWhiteSpace(pessoa.Rua) ? "Não informado" : pessoa.Rua);
                                    });

                                col.Item().Element(CampoDetalhePdf)
.Text(text =>
{
    text.Span("Bairro: ").Bold();
    text.Span(string.IsNullOrWhiteSpace(pessoa.Bairro) ? "Não informado" : pessoa.Bairro);
});

                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("Nº: ").Bold();
                                        text.Span(string.IsNullOrWhiteSpace(pessoa.Numero) ? "Não informado" : pessoa.Numero);
                                    });

                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("Cidade: ").Bold();
                                        text.Span(string.IsNullOrWhiteSpace(pessoa.Cidade) ? "Não informado" : pessoa.Cidade);
                                    });

                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("Estado: ").Bold();
                                        text.Span(string.IsNullOrWhiteSpace(pessoa.Estado) ? "Não informado" : pessoa.Estado);
                                    });

                                col.Item().Element(CampoDetalhePdf)
                                    .Text(text =>
                                    {
                                        text.Span("Data de cadastro: ").Bold();
                                        text.Span(pessoa.DataCadastro.ToString("dd/MM/yyyy HH:mm"));
                                    });
                            });

                        content.Item()
                            .PaddingTop(18)
                            .Text("Observação")
                            .FontSize(12)
                            .Bold()
                            .FontColor(Colors.Grey.Darken2);

                        content.Item()
                            .PaddingTop(6)
                            .Text("Este documento foi gerado automaticamente pelo CadastroApp.")
                            .FontSize(9)
                            .FontColor(Colors.Grey.Darken1);
                    });

                page.Footer()
                    .PaddingTop(10)
                    .Column(footer =>
                    {
                        footer.Item()
                            .LineHorizontal(1)
                            .LineColor(Colors.Grey.Lighten2);

                        footer.Item()
                            .PaddingTop(6)
                            .Row(row =>
                            {
                                row.RelativeItem()
                                    .Text("CadastroApp - Ficha individual")
                                    .FontSize(8)
                                    .FontColor(Colors.Grey.Darken1);

                                row.RelativeItem()
                                    .AlignRight()
                                    .Text(texto =>
                                    {
                                        texto.Span("Página ")
                                            .FontSize(8)
                                            .FontColor(Colors.Grey.Darken1);

                                        texto.CurrentPageNumber()
                                            .FontSize(8)
                                            .FontColor(Colors.Grey.Darken1);

                                        texto.Span(" de ")
                                            .FontSize(8)
                                            .FontColor(Colors.Grey.Darken1);

                                        texto.TotalPages()
                                            .FontSize(8)
                                            .FontColor(Colors.Grey.Darken1);
                                    });
                            });
                    });
            });
        })
        .GeneratePdf(caminhoArquivo);

        return caminhoArquivo;
    }

    static IContainer CampoDetalhePdf(IContainer container)
    {
        return container
            .PaddingVertical(6)
            .BorderBottom(1)
            .BorderColor(Colors.Grey.Lighten3);
    }

    static string CriarNomeArquivoSeguro(string? nome)
    {
        if (string.IsNullOrWhiteSpace(nome))
        {
            return "cliente";
        }

        var caracteresInvalidos = Path.GetInvalidFileNameChars();

        var nomeSeguro = new string(
            nome.Select(c => caracteresInvalidos.Contains(c) ? '_' : c).ToArray()
        );

        nomeSeguro = nomeSeguro.Replace(" ", "_");

        return nomeSeguro;
    }

}